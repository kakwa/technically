flowchart TB

    %% ========== STYLES ==========
    classDef internet fill:#f3f4f6,stroke:#9ca3af,color:#111827

    classDef k8s fill:#f8fafc,stroke:#3b82f6,stroke-width:2px,color:#1e3a8a

    %% ========== INTERNET ==========
    Internet["🌍 Internet"]
    class Internet internet

    subgraph K8S["Kubernetes"]
    %% ========== GATEWAY ==========
    subgraph AddOns["Workers"]
        Gateway["🚪 Gateway API (Traefik)\n• HTTP/TCP Routing\n• TLS Termination"]
        class Gateway gateway
        ExternalDNS["ExternalDNS"]
        MetalLB["MetalLB"]
    end

    %% ========== WORKER RUNTIME ==========
    subgraph Runtime["Workers"]
        direction TB

        subgraph W1["Worker Node 1"]
            W1_stack["⚙️ kubelet\n📦 containerd"]
            W1_pods["🧩 Pods\n(App + Sidecars)"]
            class W1_stack worker
            class W1_pods pod
        end

        subgraph W2["Worker Node 2"]
            W2_stack["⚙️ kubelet\n📦 containerd"]
            W2_pods["🧩 Pods"]
            class W2_stack worker
            class W2_pods pod
        end

        subgraph WN["Worker Node N"]
            WN_stack["⚙️ kubelet\n📦 containerd"]
            WN_pods["🧩 Pods"]
            class WN_stack worker
            class WN_pods pod
        end
    end

    %% ========== CONTROL PLANE ==========
    subgraph ControlPlane["🟪 Control Plane"]
        direction TB

        API["🧠 kube-apiserver\nKubernetes API\nAuthN/AuthZ"]
        Scheduler["📅 kube-scheduler"]
        Controller["🔁 controller-manager"]
        Etcd["🗄️ etcd\n(cluster state)"]

        class API control
        class Scheduler control
        class Controller control
        class Etcd etcd
    end
    class K8S k8s
    end


    %% ========== FLOWS ==========
    Internet --> Gateway
    Gateway --> Runtime

    %% Gateway to pods
    Gateway --> W1_pods
    Gateway --> W2_pods
    Gateway --> WN_pods

    %% Control plane communication
    W1_stack -. "mTLS API" .-> API
    W2_stack -. "mTLS API" .-> API
    WN_stack -. "mTLS API" .-> API

    %% Control plane internals
    API --> Scheduler
    API --> Controller
    Scheduler --> Etcd
    Controller --> Etcd
    API --> Etcd
